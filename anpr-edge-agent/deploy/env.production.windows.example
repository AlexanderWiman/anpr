# Production env for Windows service install
# Installed to: C:\ProgramData\anpr-edge-agent\.env
#
# For multi-site installers use sites\*.env + choose-site.ps1 instead.

BACKEND_URL=https://example.up.railway.app
ANPR_AGENT_TOKEN=change-me-use-strong-token

SITE_ID=falun
CAMERA_ID=entrance-1
DIRECTION=entry
CAMERA_RTSP_URL=rtsp://user:pass@192.168.1.100:554/stream1

BOOKING_HINTS_ENABLED=true
YOLO_MODEL_PATH=C:\Program Files\anpr-edge-agent\models\plate_yolov8.pt
MIN_CONFIDENCE=0.55
OCR_MIN_CONFIDENCE=0.55
PLATE_COOLDOWN_SECONDS=60

STORAGE_DIR=C:\ProgramData\anpr-edge-agent\storage
SAVE_SNAPSHOTS=false

HEALTH_HOST=0.0.0.0
HEALTH_PORT=8080
AGENT_AUTO_START=false

LOG_LEVEL=INFO
LOG_DIR=C:\ProgramData\anpr-edge-agent\logs
