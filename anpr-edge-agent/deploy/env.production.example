# Production env for systemd install
# Installed to: /etc/anpr-edge-agent/env
#
# Prefer site profiles: copy .env.example + sites/<site>.env on the host.
# This file is used by install-systemd.sh as a starting template.

BACKEND_URL=https://example.up.railway.app
ANPR_AGENT_TOKEN=change-me-use-strong-token

SITE_ID=falun
CAMERA_ID=entrance-1
DIRECTION=entry
CAMERA_RTSP_URL=rtsp://user:pass@192.168.1.100:554/stream1

BOOKING_HINTS_ENABLED=true
YOLO_MODEL_PATH=/opt/anpr-edge-agent/models/plate_yolov8.pt
MIN_CONFIDENCE=0.55
OCR_MIN_CONFIDENCE=0.55
PLATE_COOLDOWN_SECONDS=60

STORAGE_DIR=/var/lib/anpr-edge-agent/storage
SAVE_SNAPSHOTS=false
FRAME_RETENTION_HOURS=24
FRAME_MAX_FILES=200
FRAME_MAX_STORAGE_MB=256

HEALTH_HOST=127.0.0.1
HEALTH_PORT=8080
AGENT_AUTO_START=false

LOG_LEVEL=INFO
LOG_DIR=/var/lib/anpr-edge-agent/logs
