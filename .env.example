# Production ANPR edge agent — RTSP camera only (no dev video / YouTube).
#
# Per site: copy sites/<name>.env.example → sites/<name>.env and set CAMERA_RTSP_URL.
# Then: ./scripts/choose-site.sh   OR use Install ANPR / launch/Installer.cmd

# --- Site (override in sites/<name>.env) ---
SITE_ID=falun
CAMERA_ID=entrance-1
DIRECTION=entry
# Tapo example: rtsp://user:password@192.168.0.96:554/stream1
CAMERA_RTSP_URL=rtsp://user:password@192.168.0.96:554/stream1

# Multi-hall sites (optional): point to a camera list JSON file.
# When set, hall cameras are loaded from this file instead of CAMERA_RTSP_URL.
# Example for Falun with two halls: CAMERAS_CONFIG=./sites/falun.cameras.json
# CAMERAS_CONFIG=./sites/falun.cameras.json

# --- Backend ---
BACKEND_URL=https://backend-production-c702.up.railway.app
ANPR_AGENT_TOKEN=change-me

# --- Booking hints (OCR disambiguation) ---
BOOKING_HINTS_ENABLED=true
BOOKING_HINTS_REFRESH_SECONDS=600

# --- Remote monitoring (heartbeat to backend) ---
HEARTBEAT_ENABLED=true
HEARTBEAT_INTERVAL_SECONDS=60

# --- YOLO + OCR ---
YOLO_MODEL_PATH=./models/plate_yolov8.pt
MIN_CONFIDENCE=0.55
OCR_MIN_CONFIDENCE=0.55
YOLO_CONFIDENCE=0.15
YOLO_MAX_IMAGE_WIDTH=1280
PLATE_COOLDOWN_SECONDS=60

# --- RTSP capture ---
FRAME_INTERVAL_MS=1000
MOTION_GATE_ENABLED=true
MOTION_SCAN_INTERVAL_MS=5000
MOTION_ACTIVE_SECONDS=45
MOTION_THRESHOLD=0.012
RTSP_CONNECT_TIMEOUT_MS=10000
RTSP_RECONNECT_DELAY_MS=5000
RTSP_TRANSPORT=tcp
RTSP_RECONNECT_DELAY_MS=5000

# --- Storage ---
STORAGE_DIR=./storage
SAVE_SNAPSHOTS=false
FRAME_RETENTION_HOURS=24
FRAME_MAX_FILES=200
FRAME_MAX_STORAGE_MB=256
FRAME_CLEANUP_INTERVAL_SEC=300

# --- Dashboard ---
HEALTH_HOST=0.0.0.0
HEALTH_PORT=8080
WEB_HISTORY_SIZE=100
AGENT_AUTO_START=false

LOG_LEVEL=INFO
LOG_DIR=./logs
